{
  "buildCommand": "npm run vercel-build",
  "framework": "nextjs",
  "regions": ["hnd1"],

  "git": {
    "deploymentEnabled": {
      "main": true,
      "staging": true
    }
  },

  "crons": [
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/integrations/google/process-jobs",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/generate-tasks",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/birthday-reminders",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/vaccination-reminders",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/service-dog-alerts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/service-dog-meeting-reminders",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/invoicing/process-jobs",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/expire-subscriptions",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/paycall-sync",
      "schedule": "0 6 * * *"
    }
  ]
}
