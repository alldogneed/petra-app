# ─────────────────────────────────────────────────────────────────────────────
# .env.example — safe to commit, contains no real secrets
# Copy this to .env.local for local development and fill in real values.
# See CLAUDE.md → "Environment Strategy" for full setup instructions.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase / Neon) ────────────────────────────────────────────────
# Transaction pooler URL (port 6543, PgBouncer) — used by the app
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true"
# Direct session URL (port 5432) — used by Prisma for migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# ── App URLs ──────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# ── Google Calendar Sync ──────────────────────────────────────────────────────
GCAL_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"
# Generate: openssl rand -hex 32
GCAL_ENCRYPTION_KEY=""

# ── Cron jobs ────────────────────────────────────────────────────────────────
# Protects /api/cron/* endpoints. Generate: openssl rand -hex 24
CRON_SECRET=""

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get at: https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="Petra <onboarding@resend.dev>"

# ── Invoicing (Morning / חשבשבת) ─────────────────────────────────────────────
# Generate: openssl rand -hex 32
INVOICING_ENCRYPTION_KEY=""

# ── Stripe ────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
STRIPE_ENCRYPTION_KEY=""

# ── Make.com Webhook ─────────────────────────────────────────────────────────
# Generate: openssl rand -hex 24
MAKE_WEBHOOK_SECRET=""
# Business ID that receives leads from Make.com webhook
WEBHOOK_BUSINESS_ID=""

# ── Vercel Blob (file uploads) ────────────────────────────────────────────────
# Get from: Vercel Dashboard → Storage → Blob → your store → .env.local button
BLOB_READ_WRITE_TOKEN=""

# ── Twilio / WhatsApp ─────────────────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Twilio sandbox number or approved business number
TWILIO_WHATSAPP_FROM="+14155238886"
