{
  "name": "petra-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "audit:routes": "node scripts/audit-route-auth.mjs",
    "build": "prisma generate && node scripts/audit-route-auth.mjs && next build",
    "vercel-build": "prisma generate --schema=prisma/schema.production.prisma && node scripts/audit-route-auth.mjs && next build",
    "postinstall": "prisma generate && cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs public/pdf.worker.min.mjs",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:seed-admin": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed-admin.ts",
    "deploy:staging": "bash scripts/deploy.sh staging",
    "deploy:production": "bash scripts/deploy.sh production"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.43.0",
    "@swc/helpers": "^0.5.19",
    "@tanstack/react-query": "^5",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/blob": "^2.3.1",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.400",
    "next": "14.2.35",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.7.0",
    "resend": "^6.9.2",
    "sonner": "^2.0.7",
    "stripe": "^20.4.0",
    "styled-jsx": "^5.1.7",
    "tailwind-merge": "^2",
    "twilio": "^5.12.2",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.24",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "8.4.47",
    "prisma": "^5",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1",
    "ts-node": "^10",
    "typescript": "^5"
  }
}
